# ─────────────────────────────────────────
# ARIA / HERMES — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
APP_NAME=ARIA
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ── Database ─────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_secret
DATABASE_URL=postgresql+asyncpg://hermes:hermes_secret@localhost:5432/hermes

# ── LLM (Qwen2.5-VL-7B-Instruct) ─────────
LLM_PROVIDER=openai              # local (transformers GPU) | openai (layer 0 external API)
LLM_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct
LLM_DEVICE=cuda                  # cuda | cpu | mps
LLM_TORCH_DTYPE=bfloat16         # bfloat16 | float16 | float32
LLM_LOAD_IN_4BIT=true            # 4-bit quantization
LLM_MAX_NEW_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_CACHE_DIR=./models           # local model cache directory

# When LLM_PROVIDER=openai — your layer 0 API base and endpoints
LLM_API_BASE=http://localhost:8080
LLM_API_KEY=not-needed           # set if your API requires a bearer token
LLM_CHAT_PATH=/v1/chat/completions    # text-only requests
LLM_MULTIMODAL_PATH=/v1/multimodal    # vision (image + text) requests

# ── Embedding Model ──────────────────────
# EMBED_PROVIDER=local → use local SentenceTransformer GPU model
# EMBED_PROVIDER=api   → call your layer 0 embedding API
EMBED_PROVIDER=api
EMBED_MODEL_ID=nomic-ai/nomic-embed-text-v1.5
EMBED_DEVICE=cuda                # only used when EMBED_PROVIDER=local
EMBED_BATCH_SIZE=32
EMBED_DIMENSION=768

# When EMBED_PROVIDER=api — your layer 0 embedding base and endpoints
EMBED_API_BASE=http://localhost:8080
EMBED_API_KEY=not-needed
EMBED_API_PATH=/v1/embeddings         # single / small batch
EMBED_BATCH_API_PATH=/v1/embeddings/batch  # large batch

# ── Whisper STT ──────────────────────────
WHISPER_MODEL_SIZE=base          # tiny|base|small|medium|large
WHISPER_DEVICE=cuda
WHISPER_LANGUAGE=en              # or null for auto-detect

# ── Email (IMAP/SMTP/Outlook) ────────────
EMAIL_CLIENT=imap                  # imap | outlook (macOS local outlook via AppleScript)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USE_SSL=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_TLS=true
EMAIL_ADDRESS=your@email.com
EMAIL_PASSWORD=your-app-password
EMAIL_POLL_INTERVAL_SECONDS=300  # check every 5 min

# ── Agent Settings ───────────────────────
AGENT_MAX_ITERATIONS=10          # max ReAct loop steps
AGENT_TIMEOUT_SECONDS=120        # max agent run time
TOOL_SANDBOX_TIMEOUT_SECONDS=30  # dynamic tool execution timeout
AUTO_PROJECT_CONFIDENCE_THRESHOLD=0.75

# ── Scheduler ────────────────────────────
WEEKLY_REPORT_DAY=sunday         # day of week
WEEKLY_REPORT_HOUR=8             # 8am
NIGHTLY_REFINEMENT_HOUR=2        # 2am

# ── Filesystem Access ─────────────────────────────────────────
# Comma-separated absolute paths Hermes can read/write
# Leave empty to disable file access entirely
FILESYSTEM_ALLOWED_PATHS=/Users/alpha/Documents,/Users/alpha/Projects
# Max file size Hermes will read in full (bytes, default 10MB)
FILESYSTEM_MAX_FILE_BYTES=10485760
# File extensions that are ALWAYS blocked from reading
FILESYSTEM_BLOCKED_EXTENSIONS=.env,.key,.pem,.p12,.pfx,.crt
